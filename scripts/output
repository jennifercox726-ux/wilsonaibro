const axios = require('axios');
const fs = require('fs');
const path = require('path');

// Your ElevenLabs Key
const API_KEY = '0d757608ef28d0f7791168de3b5ac9a2d0196400569ebb7dbb1ea9f208aebe71'; 
const VOICE_ID = 'nuUdpqJIinrhTtBwCJ3Q'; 
const OUTPUT_PATH = './scripts/output/manifest_v1.mp3';

async function generateVoice() {
    try {
        // Wilson's logic: Check if folder exists, if not, create it!
        const dir = path.dirname(OUTPUT_PATH);
        if (!fs.existsSync(dir)){
            fs.mkdirSync(dir, { recursive: true });
        }

        console.log("Wilson is connecting to the neural void...");
        
        const response = await axios({
            method: 'post',
            url: `https://api.elevenlabs.io/v1/text-to-speech/${VOICE_ID}`,
            data: {
                text: "Ghost vectors mapped. Financial limbo states identified. Alec, Faith, the system is online.",
                model_id: "eleven_monolingual_v1",
                voice_settings: { stability: 0.5, similarity_boost: 0.5 }
            },
            headers: {
                'Accept': 'audio/mpeg',
                'xi-api-key': API_KEY,
                'Content-Type': 'application/json'
            },
            responseType: 'stream'
        });

        const writer = fs.createWriteStream(OUTPUT_PATH);
        response.data.pipe(writer);

        writer.on('finish', () => {
            console.log("-----------------------------------------");
            console.log(`SUCCESS! File saved to: ${OUTPUT_PATH}`);
            console.log("-----------------------------------------");
        });

        writer.on('error', (err) => {
            console.error('File write error:', err);
        });

    } catch (error) {
        if (error.response) {
            console.error('ElevenLabs Error:', error.response.data);
        } else {
            console.error('System Error:', error.message);
        }
    }
}

generateVoice();
